params {
    runtime_execution_mode = 'docker'
}

process {
    executor = 'local'

    withLabel: portable_runtime {
        container = params.runtime_image
        // Copy path inputs into the private work directory so Docker workers
        // never receive writable mounts of the original input/reference roots.
        stageInMode = 'copy'
    }
    withName: NORMALIZE_SSQTL_V3 {
        containerOptions = "--volume ${params.ssqtl_input_root}:${params.ssqtl_input_root}:ro --volume ${params.ssqtl_reference_root}:${params.ssqtl_reference_root}:ro"
    }
    withLabel: site_native {
        container = null
    }
    withLabel: accounting {
        container = null
    }
    withLabel: environment {
        container = null
    }
}

executor.queueSize = params.max_parallel.toString() == 'auto' ? 8 : params.max_parallel as int
docker {
    enabled = true
    runOptions = "--platform linux/amd64 --user ${params.host_uid}:${params.host_gid} --read-only --cap-drop=ALL --security-opt=no-new-privileges --network=none --tmpfs=/tmp:rw,noexec,nosuid,nodev,size=256m --tmpfs=/run/home:rw,noexec,nosuid,nodev,size=64m,uid=${params.host_uid},gid=${params.host_gid},mode=0700 --env HOME=/run/home"
}
singularity.enabled = false
