params {
    helper_sif = null
    helper_sif_sha256 = null
    // Legacy v2 entry workflows still require a helper SIF, but all site paths
    // and scheduler accounts must come from an operator-owned private config.
    require_helper_sif = true
    runtime_sif = null
    runtime_sif_sha256 = null
    runtime_execution_mode = 'scc'
    software_root = null
    container_root = null
    work_root = null
    session_root = null
    results_parent = null
    enable_reports = true
}

process {
    executor = 'sge'
    withLabel: helper {
        container = params.helper_sif
    }
    withLabel: environment {
        beforeScript = "module purge; module load python3/3.10.12 R/4.5.2 igv/2.16.2 htslib/1.18 samtools/1.18; export PYTHONPATH='${projectDir}/src'"
    }
    withLabel: accounting {
        beforeScript = "module purge; module load python3/3.10.12; export PYTHONPATH='${projectDir}/src'"
    }
    withLabel: portable_runtime {
        container = params.runtime_sif
        containerOptions = '--containall --no-home'
        clusterOptions = {
            def project = params.scc_project?.toString()
            def qname = params.scc_qname?.toString()
            if (!(project ==~ /[A-Za-z0-9][A-Za-z0-9._-]{0,127}/)) {
                throw new IllegalArgumentException('scc_project is required and contains unsafe characters')
            }
            if (qname && !(qname ==~ /[A-Za-z0-9][A-Za-z0-9._-]{0,127}/)) {
                throw new IllegalArgumentException('scc_qname contains unsafe characters')
            }
            qname ? "-P ${project} -q ${qname}" : "-P ${project}"
        }
    }
    withName: NORMALIZE_SSQTL_V3 {
        container = params.runtime_sif
        containerOptions = "--containall --no-home --bind ${params.ssqtl_input_root}:${params.ssqtl_input_root}:ro,${params.ssqtl_reference_root}:${params.ssqtl_reference_root}:ro"
    }
    withLabel: portable_render {
        container = params.runtime_sif
        containerOptions = '--containall --no-home'
    }
    withLabel: igv_render {
        beforeScript = "module purge; module load python3/3.10.12 R/4.5.2 igv/2.16.2 htslib/1.18 samtools/1.18; export PYTHONPATH='${projectDir}/src'"
        cpus = 1
        memory = '8 GB'
        time = '30 min'
        maxForks = params.max_parallel.toString() == 'auto' ? 8 : params.max_parallel as int
    }
}

executor.queueSize = params.max_parallel.toString() == 'auto' ? 8 : params.max_parallel as int
trace.enabled = true
report.enabled = true
timeline.enabled = true
dag.enabled = true
singularity {
    enabled = true
    autoMounts = true
}
docker.enabled = false
