{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Luckyfruit88/IGV-Pipeline/schema/run-provenance.schema.json",
  "title": "Run-level immutable provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "pipeline_version", "pipeline_commit", "run_id", "generation_id",
    "created_at", "canonical_manifest", "parameters", "software", "references",
    "shards", "accounting", "publication"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "pipeline_version": {"const": "2.0.0"},
    "pipeline_commit": {"$ref": "#/$defs/gitCommit"},
    "run_id": {"$ref": "#/$defs/safeId"},
    "generation_id": {"$ref": "#/$defs/safeId"},
    "created_at": {"type": "string", "format": "date-time"},
    "canonical_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "sha256", "task_set_sha256", "task_count"],
      "properties": {
        "relative_path": {"type": "string", "pattern": "^(?!/).+$"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "task_set_sha256": {"$ref": "#/$defs/sha256"},
        "task_count": {"type": "integer", "minimum": 1}
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "sha256"],
      "properties": {
        "relative_path": {"type": "string", "pattern": "^(?!/).+$"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "software": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/software"}
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/reference"}
    },
    "shards": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/shard"}
    },
    "accounting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_tasks", "trace_tasks", "terminal_results", "accounted_tasks", "status"],
      "properties": {
        "expected_tasks": {"type": "integer", "minimum": 0},
        "trace_tasks": {"type": "integer", "minimum": 0},
        "terminal_results": {"type": "integer", "minimum": 0},
        "accounted_tasks": {"type": "integer", "minimum": 0},
        "status": {"enum": ["PENDING", "RECONCILED", "FAILED"]}
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "result_root", "checksums_sha256"],
      "properties": {
        "state": {"enum": ["NOT_READY", "READY", "PUBLISHED", "WITHHELD"]},
        "result_root": {"type": "string", "pattern": "^/"},
        "checksums_sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      }
    }
  },
  "$defs": {
    "safeId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"},
    "safeIdLong": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,255}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "gitCommit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "software": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "executable", "sha256"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "executable": {"type": ["string", "null"]},
        "sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "sha256"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "path": {"type": "string", "pattern": "^/"},
        "sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      }
    },
    "shard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shard_id", "task_count", "task_set_sha256", "session_id", "status"],
      "properties": {
        "shard_id": {"$ref": "#/$defs/safeId"},
        "task_count": {"type": "integer", "minimum": 1},
        "task_set_sha256": {"$ref": "#/$defs/sha256"},
        "session_id": {
          "oneOf": [
            {"$ref": "#/$defs/safeIdLong"},
            {"type": "null"}
          ]
        },
        "status": {"enum": ["PLANNED", "RUNNING", "COMPLETED", "FAILED"]}
      }
    }
  }
}
