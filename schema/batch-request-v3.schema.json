{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Luckyfruit88/IGV-Pipeline/schema/batch-request-v3.schema.json",
  "title": "IGV Pipeline immutable campaign batch request 3.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "created_at", "campaign_id", "campaign_contract_sha256",
    "batch_id", "batch_index", "purpose", "execution_profile", "execution_run_id",
    "execution_generation_id", "master_task_count", "master_tasks_sha256",
    "master_task_set_sha256", "pilot_selection_sha256", "tasks_relative_path",
    "task_count", "tasks_sha256", "task_set_sha256", "source_tasks",
    "request_sha256"
  ],
  "properties": {
    "schema_version": {"const": "3.0-batch-request"},
    "created_at": {"type": "string", "format": "date-time"},
    "campaign_id": {"$ref": "#/$defs/safeId"},
    "campaign_contract_sha256": {"$ref": "#/$defs/sha256"},
    "batch_id": {"$ref": "#/$defs/safeId"},
    "batch_index": {"type": "integer", "minimum": 1},
    "purpose": {"enum": ["PILOT_QA", "PRODUCTION_CONTINUATION"]},
    "execution_profile": {"const": "scc"},
    "execution_run_id": {"$ref": "#/$defs/safeId"},
    "execution_generation_id": {"$ref": "#/$defs/safeId"},
    "master_task_count": {"const": 8973},
    "master_tasks_sha256": {"$ref": "#/$defs/sha256"},
    "master_task_set_sha256": {"$ref": "#/$defs/sha256"},
    "pilot_selection_sha256": {
      "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
    },
    "tasks_relative_path": {
      "type": "string",
      "pattern": "^batches/[A-Za-z0-9][A-Za-z0-9._-]{0,79}/tasks\\.jsonl$"
    },
    "task_count": {"type": "integer", "minimum": 1, "maximum": 256},
    "tasks_sha256": {"$ref": "#/$defs/sha256"},
    "task_set_sha256": {"$ref": "#/$defs/sha256"},
    "source_tasks": {
      "type": "array", "minItems": 1, "maxItems": 256,
      "items": {"$ref": "#/$defs/sourceTask"}
    },
    "request_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "safeId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"},
    "safeTaskId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,255}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sourceTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id", "source_manifest_order", "source_input_fingerprint",
        "batch_manifest_order", "batch_input_fingerprint"
      ],
      "properties": {
        "task_id": {"$ref": "#/$defs/safeTaskId"},
        "source_manifest_order": {"type": "integer", "minimum": 1, "maximum": 8973},
        "source_input_fingerprint": {"$ref": "#/$defs/sha256"},
        "batch_manifest_order": {"type": "integer", "minimum": 1, "maximum": 256},
        "batch_input_fingerprint": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
